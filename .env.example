# ==============================================
# VENUES API - ENVIRONMENT CONFIGURATION
# ==============================================
# SECURITY WARNING: Never commit .env files to git!
# Copy this to .env and fill with your values
# ==============================================

# ENVIRONMENT
SPRING_PROFILES_ACTIVE=dev

# DATABASE (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/venues
DB_USERNAME=admin
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# JWT AUTHENTICATION
# CRITICAL: Generate strong secret with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# EMAIL (SMTP)
MAIL_USERNAME=example@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# REDIS CACHE (Upstash or Local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_DATABASE=0

# CORS CONFIGURATION (Production)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://venues.app,https://admin.venues.app

# FRONTEND BASE URL (used for email links)
FRONTEND_URL=http://localhost:3000

# COOKIE SECURITY (set to true in production)
COOKIE_SECURE=false
