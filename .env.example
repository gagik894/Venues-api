# ==========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
#
# GitHub Actions Classification:
#   [SECRET]   -> Goes in PROD_ENV_FILE repository secret (masked in logs)
#   [VARIABLE] -> Goes in Repository Variables (visible, auditable)
#   [LOCAL]    -> Only for local development, not needed in production
#
# ==========================================

# ==========================================
# SECRETS (Add to PROD_ENV_FILE in GitHub)
# ==========================================

# Database [SECRET]
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/venues_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Mail [SECRET]
SPRING_MAIL_USERNAME=user@example.com
SPRING_MAIL_PASSWORD=app-password

# Redis [SECRET]
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0
SPRING_DATA_REDIS_SSL_ENABLED=false

# JWT Secret [SECRET] (Must be 32+ chars)
APP_SECURITY_JWT_SECRET=your-256-bit-secret-key-must-be-very-long-and-secure

# Frontend Revalidation [SECRET] (Must be 32+ chars)
FRONTEND_REVALIDATION_SECRET=your-frontend-revalidation-secret-min-32-chars

# Payment URLs [SECRET]
APP_PAYMENT_BASE_URL=http://localhost:8080
APP_PAYMENT_FRONTEND_URL=http://localhost:3000

# Cookie Security [SECRET]
COOKIE_SECURE=false

# Media Storage Credentials [SECRET]
VENUES_MEDIA_S3_ACCESS_KEY=your-access-key
VENUES_MEDIA_S3_SECRET_KEY=your-secret-key

# ==========================================
# VARIABLES (Add to Repository Variables)
# ==========================================

# Frontend URL [VARIABLE]
FRONTEND_URL=http://localhost:3000

# CORS Origins [VARIABLE] (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Media Storage Config [VARIABLE]
VENUES_MEDIA_STORAGE_TYPE=local
VENUES_MEDIA_S3_ENDPOINT=https://[project-id].supabase.co/storage/v1/s3
VENUES_MEDIA_S3_REGION=us-east-1
VENUES_MEDIA_S3_BUCKET=your-bucket-name
VENUES_MEDIA_S3_PUBLIC_URL=https://[project-id].supabase.co/storage/v1/object/public/[bucket-name]

# ==========================================
# LOCAL ONLY (Not needed in production)
# ==========================================

# Active Profile [LOCAL] (set via docker-compose in prod)
SPRING_PROFILES_ACTIVE=dev

# Flyway [LOCAL] (always true in prod properties file)
FLYWAY_CLEAN_DISABLED=false

# Server Port [LOCAL] (defaults to 8080)
SERVER_PORT=8080
